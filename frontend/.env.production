# Production environment variables
# WebSocket URL will use the same origin as the app
# VITE_WS_URL is intentionally unset — useWebSocket.ts falls back to
# the dynamic WS_BASE_URL from config/api.ts (uses window.location.hostname),
# so the app works on any IP (localhost, 127.0.0.1, or LAN 192.168.x.x).
# VITE_WS_URL=
