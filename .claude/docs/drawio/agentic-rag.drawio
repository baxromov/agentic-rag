        <mxCell id="p5-bk3b" value="mc mirror / rsync + cron" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff9f0;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="p5-1"><mxGeometry x="190" y="538" width="220" height="30" as="geometry" /></mxCell>
