  <!-- ═══════════════════════════════════════════════════════════════
       PAGE 3 — INGESTION PIPELINE
       ═══════════════════════════════════════════════════════════════ -->
  <diagram id="ingestion" name="3. Ingestion Pipeline">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="p3-0" />
        <mxCell id="p3-1" parent="p3-0" />
        <mxCell id="p3-title" value="Document Ingestion Pipeline" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=20;" vertex="1" parent="p3-1">
          <mxGeometry x="527" y="20" width="600" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p3-up" value="&lt;b&gt;1. Upload&lt;/b&gt;&#xa;POST /documents/upload&#xa;multipart form&#xa;PDF/DOCX/Images" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="p3-1">
          <mxGeometry x="40" y="290" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p3-minio" value="&lt;b&gt;MinIO (S3)&lt;/b&gt;&#xa;Store original file&#xa;{doc_id}/{filename}" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="p3-1">
          <mxGeometry x="40" y="120" width="180" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p3-dedup" value="&lt;b&gt;SHA256 Dedup&lt;/b&gt;&#xa;Compute hash&#xa;Check Qdrant payload&#xa;Duplicate → 409" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fffacd;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="p3-1">
          <mxGeometry x="260" y="262" width="200" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p3-parse" value="&lt;b&gt;3. Parse&lt;/b&gt;&#xa;unstructured library&#xa;Tesseract OCR (uzb/rus/eng)&#xa;libmagic · poppler&#xa;libreoffice · pandoc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="p3-1">
          <mxGeometry x="500" y="268" width="200" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p3-chunk" value="&lt;b&gt;4. Chunk (Two-tier)&lt;/b&gt;&#xa;Parent: size=2000 overlap=100&#xa;Child: size=500 overlap=100&#xa;Child → stores parent_text&#xa;+ parent_chunk_index" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="p3-1">
          <mxGeometry x="740" y="268" width="210" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p3-lang" value="&lt;b&gt;5. Language Detect&lt;/b&gt;&#xa;langdetect · first 500 chars&#xa;uz / ru / en&#xa;tr→uz · fallback: uz" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="p3-1">
          <mxGeometry x="990" y="268" width="190" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p3-dense" value="&lt;b&gt;6a. Dense Embed  [GPU Server]&lt;/b&gt;&#xa;Embedding Model&#xa;768-dim · batch=64 · timeout=300s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="p3-1">
          <mxGeometry x="990" y="100" width="270" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p3-sparse" value="&lt;b&gt;6b. Sparse Embed  [App Server]&lt;/b&gt;&#xa;model-server /sparse-embed&#xa;Qdrant/bm25 · batch=128 · timeout=120s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="p3-1">
          <mxGeometry x="990" y="430" width="270" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p3-hyp" value="&lt;b&gt;7. Hypothetical Qs  [GPU Server]&lt;/b&gt;&#xa;LLM generates 3 Q/parent chunk&#xa;Embed dense+sparse&#xa;point_type=hypothetical_question" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="p3-1">
          <mxGeometry x="1310" y="268" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p3-qdrant" value="&lt;b&gt;8. Upsert to Qdrant&lt;/b&gt;&#xa;document_id · file_hash&#xa;page_number · chunk_index&#xa;parent_chunk_index · language&#xa;section_header · element_types&#xa;point_type · created_at" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="p3-1">
          <mxGeometry x="1310" y="510" width="240" height="175" as="geometry" />
        </mxCell>
        <mxCell id="p3-eu" value="store" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#d6b656;fontSize=9;" edge="1" source="p3-up" target="p3-minio" parent="p3-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-e1" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p3-up" target="p3-dedup" parent="p3-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-e2" value="new" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#22c55e;fontColor=#22c55e;fontSize=9;fontStyle=1;" edge="1" source="p3-dedup" target="p3-parse" parent="p3-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-e3" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p3-parse" target="p3-chunk" parent="p3-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-e4" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p3-chunk" target="p3-lang" parent="p3-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-e5" value="GPU" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#b85450;fontColor=#b85450;fontSize=9;" edge="1" source="p3-lang" target="p3-dense" parent="p3-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-e6" value="CPU" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#9673a6;fontColor=#9673a6;fontSize=9;" edge="1" source="p3-lang" target="p3-sparse" parent="p3-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-e7" value="GPU" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#82b366;fontSize=9;" edge="1" source="p3-lang" target="p3-hyp" parent="p3-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-e8" value="dense" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;strokeColor=#d6b656;fontSize=9;" edge="1" source="p3-dense" target="p3-qdrant" parent="p3-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-e9" value="sparse" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.6;entryDx=0;entryDy=0;strokeColor=#d6b656;fontSize=9;" edge="1" source="p3-sparse" target="p3-qdrant" parent="p3-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-e10" value="hyp" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;fontSize=9;" edge="1" source="p3-hyp" target="p3-qdrant" parent="p3-1"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <!-- ═══════════════════════════════════════════════════════════════
       PAGE 4 — HYBRID SEARCH RRF
       ═══════════════════════════════════════════════════════════════ -->
  <diagram id="hybrid-search" name="4. Hybrid Search (RRF)">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="p4-0" />
        <mxCell id="p4-1" parent="p4-0" />
        <mxCell id="p4-query" value="&lt;b&gt;User Query&lt;/b&gt;  (rewritten by query_prepare)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=12;" vertex="1" parent="p4-1">
          <mxGeometry x="384" y="30" width="400" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p4-de" value="&lt;b&gt;Dense Embed  [GPU Server]&lt;/b&gt;&#xa;Embedding Model&#xa;768-dim · query timeout=60s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="p4-1">
          <mxGeometry x="100" y="155" width="290" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p4-se" value="&lt;b&gt;Sparse Embed  [App Server CPU]&lt;/b&gt;&#xa;model-server /sparse-embed&#xa;Qdrant/bm25 · timeout=120s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="p4-1">
          <mxGeometry x="770" y="155" width="290" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p4-dp" value="&lt;b&gt;Dense Prefetch&lt;/b&gt;&#xa;Qdrant cosine similarity&#xa;top = 30 candidates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="p4-1">
          <mxGeometry x="100" y="300" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4-sp" value="&lt;b&gt;Sparse Prefetch&lt;/b&gt;&#xa;Qdrant BM25 scoring&#xa;top = 30 candidates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="p4-1">
          <mxGeometry x="770" y="300" width="290" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4-filt" value="&lt;b&gt;Metadata Filter (optional)&lt;/b&gt;&#xa;language · document_id · file_type" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#adb5bd;fontSize=10;dashed=1;" vertex="1" parent="p4-1">
          <mxGeometry x="409" y="300" width="340" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p4-rrf" value="&lt;b&gt;RRF Fusion  (Reciprocal Rank Fusion)&lt;/b&gt;&#xa;k = 40     score  =  Σ  1 / (k + rank_i)&#xa;Combines dense + sparse ranks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" vertex="1" parent="p4-1">
          <mxGeometry x="259" y="445" width="650" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p4-boost" value="&lt;b&gt;Language Boost  +10%&lt;/b&gt;&#xa;if doc.language == query.language" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="p4-1">
          <mxGeometry x="384" y="595" width="400" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p4-top" value="&lt;b&gt;Top-15 Results&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="p4-1">
          <mxGeometry x="434" y="730" width="300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p4-next" value="↓  continues →  rerank  (model-server :8080)  →  grade_documents  →  expand_context  →  generate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#adb5bd;fontStyle=2;fontSize=10;" vertex="1" parent="p4-1">
          <mxGeometry x="234" y="855" width="700" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p4-e1" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="p4-query" target="p4-de" parent="p4-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p4-e2" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="p4-query" target="p4-se" parent="p4-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p4-e3" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p4-de" target="p4-dp" parent="p4-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p4-e4" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p4-se" target="p4-sp" parent="p4-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p4-e5" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="p4-dp" target="p4-rrf" parent="p4-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p4-e6" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="p4-sp" target="p4-rrf" parent="p4-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p4-e7" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="p4-filt" target="p4-rrf" parent="p4-1"><mxGeometry relative="1" as="geometry" /></mxCell>
