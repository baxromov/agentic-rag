        <mxCell id="p5-btb" value="Separate HDD (not on primary NVMe)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d79b00;strokeColor=#7a4d00;fontColor=#ffffff;fontStyle=1;fontSize=10;" vertex="1" parent="p5-1"><mxGeometry x="190" y="568" width="220" height="36" as="geometry" /></mxCell>
        <mxCell id="p5-btc" value="Cron (off-peak)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d79b00;strokeColor=#7a4d00;fontColor=#ffffff;fontStyle=1;fontSize=10;" vertex="1" parent="p5-1"><mxGeometry x="410" y="568" width="110" height="36" as="geometry" /></mxCell>
        <mxCell id="p5-btd" value="7 days" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d79b00;strokeColor=#7a4d00;fontColor=#ffffff;fontStyle=1;fontSize=10;" vertex="1" parent="p5-1"><mxGeometry x="520" y="568" width="100" height="36" as="geometry" /></mxCell>
        <mxCell id="p5-bte" value="2 TB HDD min" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d79b00;strokeColor=#7a4d00;fontColor=#ffffff;fontStyle=1;fontSize=10;" vertex="1" parent="p5-1"><mxGeometry x="620" y="568" width="100" height="36" as="geometry" /></mxCell>
        <mxCell id="p5-btf" value="Recommended: 2× 4TB HDD (RAID 1 mirror) → ~4 TB usable · physically separate from primary" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d79b00;strokeColor=#7a4d00;fontColor=#ffffff;fontStyle=1;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="p5-1"><mxGeometry x="720" y="568" width="380" height="36" as="geometry" /></mxCell>

