  <diagram id="agent-flow" name="2. LangGraph Agent Flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="p2-0" />
        <mxCell id="p2-1" parent="p2-0" />
        <mxCell id="p2-start" value="▶  START&#xa;user query + thread_id" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#7986cb;fontColor=#e8eaf6;fontStyle=1;fontSize=11;" vertex="1" parent="p2-1">
          <mxGeometry x="384" y="30" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p2-is" value="&lt;b&gt;input_safety&lt;/b&gt;&#xa;LLM guardrail · structured output (InputSafetyResult)&#xa;Detects: identity probe · jailbreak · injection · manipulation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6e6;strokeColor=#cc0000;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="284" y="140" width="500" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p2-end-safe" value="END&#xa;Canned safe response" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6e6;strokeColor=#b85450;fontColor=#b85450;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="880" y="155" width="200" height="45" as="geometry" />
        </mxCell>
        <mxCell id="p2-ir" value="&lt;b&gt;intent_router&lt;/b&gt;&#xa;Fast: regex greeting/thanks (no LLM)&#xa;LLM: hr_query vs general_query" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fffacd;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="309" y="273" width="450" height="95" as="geometry" />
        </mxCell>
        <mxCell id="p2-gr" value="&lt;b&gt;greeting_response&lt;/b&gt;&#xa;No LLM · static&#xa;Multilingual uz/ru/en" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="30" y="295" width="220" height="65" as="geometry" />
        </mxCell>
        <mxCell id="p2-end-greet" value="END (greeting)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1a5c2e;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="60" y="403" width="160" height="42" as="geometry" />
        </mxCell>
        <mxCell id="p2-genr" value="&lt;b&gt;general_response&lt;/b&gt;&#xa;Direct LLM · no RAG" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="880" y="293" width="220" height="65" as="geometry" />
        </mxCell>
        <mxCell id="p2-qp" value="&lt;b&gt;query_prepare&lt;/b&gt;&#xa;1× LLM call → JSON: rewrite + multi-query ×3&#xa;step-back query + metadata filters" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="284" y="435" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2-ret" value="&lt;b&gt;retrieve&lt;/b&gt;&#xa;Dense: Embedding Model 768-dim (GPU Server)&#xa;Sparse: model-server BM25 (App Server CPU)&#xa;Qdrant RRF k=40 → top_k=15  +lang boost +10%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="284" y="585" width="500" height="95" as="geometry" />
        </mxCell>
        <mxCell id="p2-rnk" value="&lt;b&gt;rerank&lt;/b&gt;&#xa;model-server :8080 /rerank · jina-reranker-v1-tiny-en (CPU)&#xa;top_k=7 · timeout=30s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="284" y="750" width="500" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p2-gd" value="&lt;b&gt;grade_documents&lt;/b&gt;  (NO LLM — threshold filter)&#xa;score ≥ 0.15 → keep  |  always keep top 3&#xa;max_score &lt; 0.25 AND retries ≥ 1  →  HITL&#xa;retries &lt; 3  →  rewrite query" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fffacd;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="259" y="898" width="550" height="105" as="geometry" />
        </mxCell>
        <mxCell id="p2-hf" value="&lt;b&gt;human_feedback&lt;/b&gt;&#xa;LangGraph interrupt()&#xa;Pauses → checkpoint in MongoDB&#xa;Multilingual clarification question&#xa;Awaits POST /chat/resume" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="880" y="910" width="260" height="95" as="geometry" />
        </mxCell>
        <mxCell id="p2-rw" value="&lt;b&gt;rewrite_query&lt;/b&gt;&#xa;LLM reformulates · retries++ (max 3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="880" y="1072" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p2-ec" value="&lt;b&gt;expand_context&lt;/b&gt;&#xa;Fast: parent_text from payload · Slow: neighbor window=1&#xa;Deduplication by chunk_index" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="284" y="1072" width="500" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p2-gen" value="&lt;b&gt;generate&lt;/b&gt;&#xa;LLM (GPU Server) · dynamic prompt · conversation history&#xa;Context budget: model_ctx − 4000 tokens · Citations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="284" y="1215" width="500" height="85" as="geometry" />
        </mxCell>
        <mxCell id="p2-os" value="&lt;b&gt;output_safety&lt;/b&gt;&#xa;LLM guardrail · structured output (OutputSafetyResult)&#xa;Detects: identity leak · model name · off-character response" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6e6;strokeColor=#cc0000;fontSize=10;" vertex="1" parent="p2-1">
          <mxGeometry x="284" y="1370" width="500" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p2-end-gen" value="✅  END  —  Answer + Sources  (SSE: generation)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1a5c2e;fontStyle=1;fontSize=11;" vertex="1" parent="p2-1">
          <mxGeometry x="334" y="1510" width="400" height="60" as="geometry" />
        </mxCell>
        <!-- edges -->
        <mxCell id="p2-e1" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2-start" target="p2-is" parent="p2-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e2" value="blocked" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#cc0000;fontColor=#cc0000;fontSize=9;fontStyle=1;" edge="1" source="p2-is" target="p2-end-safe" parent="p2-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e3" value="safe" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#22c55e;fontColor=#22c55e;fontSize=9;fontStyle=1;" edge="1" source="p2-is" target="p2-ir" parent="p2-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e4" value="greeting" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#82b366;fontSize=9;" edge="1" source="p2-ir" target="p2-gr" parent="p2-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e5" value="general_query" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6c8ebf;fontSize=9;" edge="1" source="p2-ir" target="p2-genr" parent="p2-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e6" value="hr_query" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;fontSize=9;fontStyle=1;" edge="1" source="p2-ir" target="p2-qp" parent="p2-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e7" value="" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p2-gr" target="p2-end-greet" parent="p2-1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e8" value="→ output_safety" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6c8ebf;fontSize=9;" edge="1" source="p2-genr" target="p2-os" parent="p2-1">
