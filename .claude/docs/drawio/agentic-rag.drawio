        <mxCell id="p5-bk3d" value="3 copies" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff9f0;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="p5-1"><mxGeometry x="520" y="538" width="100" height="30" as="geometry" /></mxCell>
        <mxCell id="p5-bk3e" value="~30–300 GB" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff9f0;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="p5-1"><mxGeometry x="620" y="538" width="100" height="30" as="geometry" /></mxCell>
        <mxCell id="p5-bk3f" value="Original PDF/DOCX files · incremental sync (only new files)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff9f0;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="p5-1"><mxGeometry x="720" y="538" width="380" height="30" as="geometry" /></mxCell>

