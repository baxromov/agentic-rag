        </mxCell>
        <mxCell id="p1_th1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4CAF50;strokeWidth=2;fontColor=#1B6B3A;fontSize=12;fontStyle=1;align=left;spacingLeft=12;" value="Architecture Domain" vertex="1">
          <mxGeometry x="40" y="104" width="210" height="38" as="geometry" />
        </mxCell>
        <mxCell id="p1_th2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4CAF50;strokeWidth=2;fontColor=#1B6B3A;fontSize=12;fontStyle=1;align=left;spacingLeft=12;" value="Changes Involved" vertex="1">
          <mxGeometry x="250" y="104" width="1270" height="38" as="geometry" />
        </mxCell>
        <!-- Row 1 Business -->
        <mxCell id="p1_r1a" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C8E6C9;fontColor=#333;fontSize=11;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" value="Business Architecture" vertex="1">
          <mxGeometry x="40" y="142" width="210" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p1_r1b" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C8E6C9;fontColor=#333;fontSize=11;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" value="The Integration Platform enhances operational efficiency by enabling seamless data and system interactions across various banking services and external partners. It supports a unified customer experience and facilitates the rollout of new services, while ensuring the platform is scalable for future needs, including integration with emerging technologies and regulatory updates. This architecture simplifies complex workflows, allowing the bank to maintain agility and respond quickly to market demands." vertex="1">
          <mxGeometry x="250" y="142" width="1270" height="110" as="geometry" />
        </mxCell>
        <!-- Row 2 Data -->
        <mxCell id="p1_r2a" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F9FBF9;strokeColor=#C8E6C9;fontColor=#333;fontSize=11;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" value="Data Architecture" vertex="1">
          <mxGeometry x="40" y="252" width="210" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p1_r2b" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F9FBF9;strokeColor=#C8E6C9;fontColor=#333;fontSize=11;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" value="The platform ensures a consistent and standardized flow of data between systems by managing APIs and integrations across the bank&#39;s ecosystem. It enforces data consistency and quality, while managing differences in data formats between internal systems and external service providers. The architecture supports efficient data exchange, allowing for smoother integration and easier system management." vertex="1">
          <mxGeometry x="250" y="252" width="1270" height="110" as="geometry" />
        </mxCell>
        <!-- Row 3 Application -->
        <mxCell id="p1_r3a" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C8E6C9;fontColor=#333;fontSize=11;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" value="Application Architecture" vertex="1">
          <mxGeometry x="40" y="362" width="210" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p1_r3b" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C8E6C9;fontColor=#333;fontSize=11;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" value="Core components include API Management, Integration Middleware, Traffic Management, Caching, and Monitoring Tools. These systems work together to manage and optimize data exchanges, ensuring reliable and secure communication between banking applications and third-party services. By handling both internal and external integrations, the platform ensures flexibility and reduces system dependencies." vertex="1">
          <mxGeometry x="250" y="362" width="1270" height="110" as="geometry" />
        </mxCell>
        <!-- Row 4 Technology -->
        <mxCell id="p1_r4a" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F9FBF9;strokeColor=#C8E6C9;fontColor=#333;fontSize=11;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" value="Technology Architecture" vertex="1">
          <mxGeometry x="40" y="472" width="210" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p1_r4b" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F9FBF9;strokeColor=#C8E6C9;fontColor=#333;fontSize=11;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" value="The platform uses a mix of modern API management technologies, caching solutions for efficient data flow, and middleware to handle complex integrations. Technologies like service mesh ensure smooth communication between internal systems, while robust monitoring tools keep the platform stable and performant. Scalability and performance are key, ensuring the platform can meet future banking requirements." vertex="1">
          <mxGeometry x="250" y="472" width="1270" height="110" as="geometry" />
        </mxCell>
        <!-- Row 5 Security -->
        <mxCell id="p1_r5a" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C8E6C9;fontColor=#333;fontSize=11;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" value="Security Architecture" vertex="1">
          <mxGeometry x="40" y="582" width="210" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p1_r5b" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C8E6C9;fontColor=#333;fontSize=11;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" value="Security is built into the platform with strong authentication methods, encrypted data transfers, and granular access controls. The architecture ensures secure interactions between systems, with continuous monitoring for vulnerabilities and threats. Regulatory compliance is maintained through regular audits and security protocols that protect the integrity of banking integrations." vertex="1">
          <mxGeometry x="250" y="582" width="1270" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p1_bline" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4CAF50;strokeColor=none;" value="" vertex="1">
          <mxGeometry x="40" y="692" width="1480" height="3" as="geometry" />
        </mxCell>
        <mxCell id="p1_pg" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=right;fontSize=10;fontColor=#999;" value="9" vertex="1">
