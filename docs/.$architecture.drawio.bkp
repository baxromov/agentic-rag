        <mxCell id="am-flow-bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=1.5;arcSize=3;" value="" vertex="1">
          <mxGeometry height="75" width="1120" x="20" y="526" as="geometry" />
        </mxCell>
        <mxCell id="am-flow-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#7B1FA2;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#ffffff;spacingLeft=10;" value="PER-USER ISOLATION FLOW" vertex="1">
          <mxGeometry height="22" width="1120" x="20" y="526" as="geometry" />
        </mxCell>
        <mxCell id="am-flow-text" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#4A148C;fontStyle=1;spacingLeft=10;" value="User opens Jira/Confluence plugin → Plugin reads user session token (PAT) → POST /chat/stream {query, user_PAT} → LangGraph agent decides which MCP tools to call →&amp;nbsp;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(74, 20, 140), rgb(232, 186, 255));&quot;&gt;→&amp;nbsp;&lt;/span&gt;Calls mcp-atlassian with &quot;Authorization: Token &quot; header → mcp-atlassian forwards user_PAT to Jira/Confluence API →&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(74, 20, 140), rgb(232, 186, 255));&quot;&gt;→&amp;nbsp;&lt;/span&gt;User sees ONLY data they have permission to access in Jira/Confluence → Full audit log in Jira/Confluence under user&#39;s own account&lt;/div&gt;" vertex="1">
          <mxGeometry height="52" width="1120" x="20" y="548" as="geometry" />
        </mxCell>
        <mxCell id="am-tools-bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#512DA8;strokeWidth=1.5;arcSize=3;" value="" vertex="1">
          <mxGeometry height="180" width="540" x="20" y="611" as="geometry" />
        </mxCell>
        <mxCell id="am-tools-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#512DA8;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#ffffff;spacingLeft=10;" value="72 MCP TOOLS  (Jira + Confluence)" vertex="1">
          <mxGeometry height="22" width="540" x="20" y="611" as="geometry" />
        </mxCell>
        <mxCell id="am-tools-text" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#1a1a2e;spacingLeft=10;spacingTop=6;" value="&lt;b&gt;Jira (35+):&lt;/b&gt; jira_search · jira_get_issue · jira_create_issue · jira_update_issue&lt;br/&gt;jira_transition_issue · jira_add_comment · jira_assign_issue · jira_get_sprint&lt;br/&gt;jira_get_board · jira_get_project · jira_get_user · jira_link_issues · ...&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Confluence (35+):&lt;/b&gt; confluence_search · confluence_get_page · confluence_create_page&lt;br/&gt;confluence_update_page · confluence_add_comment · confluence_get_space&lt;br/&gt;confluence_get_child_pages · confluence_get_page_by_title · ..." vertex="1">
          <mxGeometry height="152" width="540" x="16" y="628" as="geometry" />
        </mxCell>
        <mxCell id="am-perm-bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBE9E7;strokeColor=#BF360C;strokeWidth=1.5;arcSize=3;" value="" vertex="1">
          <mxGeometry height="191" width="560" x="575" y="611" as="geometry" />
        </mxCell>
        <mxCell id="am-perm-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#BF360C;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#ffffff;spacingLeft=10;" value="REQUIRED PERMISSIONS &amp; ACCESS" vertex="1">
          <mxGeometry height="22" width="560" x="575" y="611" as="geometry" />
        </mxCell>
        <mxCell id="am-perm-text" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#1a1a2e;spacingLeft=10;spacingTop=4;" value="&lt;b&gt;Each bank user (Jira):&lt;/b&gt;&lt;br/&gt;• PAT: Jira → Profile → Personal Access Tokens → Create&lt;br/&gt;• Plugin stores PAT in user session (not server-side)&lt;br/&gt;• User&#39;s existing project roles apply — no extra permissions needed&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Each bank user (Confluence):&lt;/b&gt;&lt;br/&gt;• PAT: Confluence → Profile → Personal Access Tokens → Create&lt;br/&gt;• User&#39;s existing space permissions apply automatically&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Network (infra team):&lt;/b&gt;&lt;br/&gt;• LangGraph server (:8000) ← inbound from Jira/Confluence plugin hosts&lt;br/&gt;• mcp-atlassian (:9000) ← inbound from LangGraph server only&lt;br/&gt;• Outbound :443 → jira.bank.internal + confluence.bank.internal" vertex="1">
          <mxGeometry height="102" width="560" x="567" y="625" as="geometry" />
        </mxCell>
        <mxCell id="am-summary-bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A237E;strokeColor=#0D1454;strokeWidth=2;arcSize=5;" value="" vertex="1">
          <mxGeometry height="26" width="1120" x="15" y="810" as="geometry" />
        </mxCell>
