  <diagram name="Shared Infrastructure" id="shared-infra">
    <mxGraphModel dx="1900" dy="1093" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="960" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="si-title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1a1a2e;" value="Shared Infrastructure — Standalone Deployment" vertex="1">
          <mxGeometry height="32" width="1360" x="20" y="12" as="geometry" />
        </mxCell>
        <mxCell id="si-subtitle" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontColor=#1565C0;fontStyle=1;" value="Qdrant · MongoDB · MinIO · Redis — deployed once, used by multiple projects/services" vertex="1">
          <mxGeometry height="18" width="1360" x="20" y="46" as="geometry" />
        </mxCell>
        <mxCell id="si-qdrant-card" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3949AB;strokeWidth=2;arcSize=3;" value="" vertex="1">
          <mxGeometry height="400" width="660" x="20" y="78" as="geometry" />
        </mxCell>
        <mxCell id="si-qdrant-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3949AB;strokeColor=#1A237E;strokeWidth=0;fontColor=#ffffff;fontSize=14;fontStyle=1;verticalAlign=middle;arcSize=5;" value="Qdrant — Vector Database" vertex="1">
          <mxGeometry height="38" width="640" x="30" y="86" as="geometry" />
        </mxCell>
        <mxCell id="si-qdrant-hw-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#C5CAE9;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#1A237E;spacingLeft=8;" value="Hardware Requirements" vertex="1">
          <mxGeometry height="22" width="640" x="30" y="132" as="geometry" />
        </mxCell>
        <mxCell id="si-qdrant-hw" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="RAM: &lt;b&gt;32 GB&lt;/b&gt; (vector index loaded into memory for fast ANN search)      CPU: &lt;b&gt;8 cores&lt;/b&gt;      Storage: &lt;b&gt;500 GB NVMe SSD&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="640" x="30" y="154" as="geometry" />
        </mxCell>
        <mxCell id="si-qdrant-net-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#C5CAE9;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#1A237E;spacingLeft=8;" value="Network &amp; Ports" vertex="1">
          <mxGeometry height="22" width="640" x="30" y="190" as="geometry" />
        </mxCell>
        <mxCell id="si-qdrant-net" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="• Port 6333 — REST API (HTTP/HTTPS)&lt;br/&gt;• Port 6334 — gRPC (high-throughput batch operations)&lt;br/&gt;• Port 6335 — internal Raft consensus (cluster mode only)&lt;br/&gt;• Bind to internal network only — never expose to public internet" vertex="1">
          <mxGeometry height="70" width="640" x="30" y="212" as="geometry" />
        </mxCell>
        <mxCell id="si-qdrant-mt-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#C5CAE9;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#1A237E;spacingLeft=8;" value="Multi-Project Isolation" vertex="1">
          <mxGeometry height="22" width="640" x="30" y="288" as="geometry" />
        </mxCell>
        <mxCell id="si-qdrant-mt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="• Separate &lt;b&gt;collection per project&lt;/b&gt; (e.g. hr_rag_docs, finance_docs, legal_docs)&lt;br/&gt;• Use &lt;b&gt;payload filters&lt;/b&gt; for sub-tenant separation within a collection&lt;br/&gt;• API key auth per collection (Qdrant v1.7+)" vertex="1">
          <mxGeometry height="56" width="640" x="30" y="310" as="geometry" />
        </mxCell>
        <mxCell id="si-qdrant-ha-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#C5CAE9;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#1A237E;spacingLeft=8;" value="High Availability &amp; Backup" vertex="1">
          <mxGeometry height="22" width="640" x="30" y="372" as="geometry" />
        </mxCell>
        <mxCell id="si-qdrant-ha" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="• Single node sufficient for up to ~50M vectors; cluster mode for larger scale&lt;br/&gt;• Snapshot API: &lt;b&gt;POST /collections/{name}/snapshots&lt;/b&gt; — schedule daily to S3/MinIO" vertex="1">
          <mxGeometry height="44" width="640" x="30" y="394" as="geometry" />
        </mxCell>
        <mxCell id="si-mongo-card" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;arcSize=3;" value="" vertex="1">
          <mxGeometry height="400" width="660" x="720" y="78" as="geometry" />
        </mxCell>
        <mxCell id="si-mongo-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;strokeColor=#1B5E20;strokeWidth=0;fontColor=#ffffff;fontSize=14;fontStyle=1;verticalAlign=middle;arcSize=5;" value="MongoDB — Document Database" vertex="1">
          <mxGeometry height="38" width="640" x="730" y="86" as="geometry" />
        </mxCell>
        <mxCell id="si-mongo-hw-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#C8E6C9;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#1B5E20;spacingLeft=8;" value="Hardware Requirements" vertex="1">
          <mxGeometry height="22" width="640" x="730" y="132" as="geometry" />
        </mxCell>
        <mxCell id="si-mongo-hw" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="RAM: &lt;b&gt;32 GB&lt;/b&gt; (WiredTiger cache = 50% RAM = 16 GB)      CPU: &lt;b&gt;8 cores&lt;/b&gt;      Storage: &lt;b&gt;500 GB NVMe SSD&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="640" x="730" y="154" as="geometry" />
        </mxCell>
        <mxCell id="si-mongo-net-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#C8E6C9;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#1B5E20;spacingLeft=8;" value="Network &amp; Ports" vertex="1">
          <mxGeometry height="22" width="640" x="730" y="190" as="geometry" />
        </mxCell>
        <mxCell id="si-mongo-net" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="• Port 27017 — primary mongod&lt;br/&gt;• Port 27018/27019 — replica set secondaries&lt;br/&gt;• Bind to internal network only — use TLS for cross-host connections&lt;br/&gt;• Enable MongoDB auth (SCRAM-SHA-256) — one user per project" vertex="1">
          <mxGeometry height="70" width="640" x="730" y="212" as="geometry" />
        </mxCell>
        <mxCell id="si-mongo-mt-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#C8E6C9;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#1B5E20;spacingLeft=8;" value="Multi-Project Isolation" vertex="1">
          <mxGeometry height="22" width="640" x="730" y="288" as="geometry" />
        </mxCell>
        <mxCell id="si-mongo-mt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="• &lt;b&gt;Separate database per project&lt;/b&gt; (e.g. hr_rag, finance_app, legal_app)&lt;br/&gt;• Dedicated user with readWrite on own DB only — no cross-DB access&lt;br/&gt;• Namespace: &lt;b&gt;mongodb://user:pass@host:27017/project_db&lt;/b&gt;" vertex="1">
          <mxGeometry height="56" width="640" x="730" y="310" as="geometry" />
        </mxCell>
        <mxCell id="si-mongo-ha-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#C8E6C9;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#1B5E20;spacingLeft=8;" value="High Availability &amp; Backup" vertex="1">
          <mxGeometry height="22" width="640" x="730" y="372" as="geometry" />
        </mxCell>
        <mxCell id="si-mongo-ha" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="• &lt;b&gt;Replica Set (3 nodes)&lt;/b&gt; recommended for production — automatic failover&lt;br/&gt;• mongodump or Percona Backup daily → store in MinIO backup bucket" vertex="1">
          <mxGeometry height="44" width="640" x="730" y="394" as="geometry" />
        </mxCell>
        <mxCell id="si-minio-card" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBE7;strokeColor=#827717;strokeWidth=2;arcSize=3;" value="" vertex="1">
          <mxGeometry height="420" width="660" x="20" y="498" as="geometry" />
        </mxCell>
        <mxCell id="si-minio-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#827717;strokeColor=#558B2F;strokeWidth=0;fontColor=#ffffff;fontSize=14;fontStyle=1;verticalAlign=middle;arcSize=5;" value="MinIO — Object Storage (S3-compatible)" vertex="1">
          <mxGeometry height="38" width="640" x="30" y="506" as="geometry" />
        </mxCell>
        <mxCell id="si-minio-hw-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#F0F4C3;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#827717;spacingLeft=8;" value="Hardware Requirements" vertex="1">
          <mxGeometry height="22" width="640" x="30" y="552" as="geometry" />
        </mxCell>
        <mxCell id="si-minio-hw" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="RAM: &lt;b&gt;32 GB&lt;/b&gt; (read cache + concurrent uploads)      CPU: &lt;b&gt;8 cores&lt;/b&gt;      Storage: &lt;b&gt;4 × 2 TB HDD or SSD&lt;/b&gt; (erasure coding requires ≥4 drives)" vertex="1">
          <mxGeometry height="30" width="640" x="30" y="574" as="geometry" />
        </mxCell>
        <mxCell id="si-minio-net-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#F0F4C3;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#827717;spacingLeft=8;" value="Network &amp; Ports" vertex="1">
          <mxGeometry height="22" width="640" x="30" y="610" as="geometry" />
        </mxCell>
        <mxCell id="si-minio-net" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="• Port 9000 — S3 API (HTTP/HTTPS) — used by all client services&lt;br/&gt;• Port 9001 — Web Console (admin only — restrict by firewall)&lt;br/&gt;• Network bandwidth: &lt;b&gt;10 Gbps&lt;/b&gt; recommended for large file throughput&lt;br/&gt;• Enable TLS on port 9000 for cross-service communication" vertex="1">
          <mxGeometry height="70" width="640" x="30" y="632" as="geometry" />
        </mxCell>
        <mxCell id="si-minio-mt-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#F0F4C3;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#827717;spacingLeft=8;" value="Multi-Project Isolation" vertex="1">
          <mxGeometry height="22" width="640" x="30" y="708" as="geometry" />
        </mxCell>
        <mxCell id="si-minio-mt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="• &lt;b&gt;Separate bucket per project&lt;/b&gt; (e.g. hr-rag-docs, finance-docs, legal-docs)&lt;br/&gt;• Dedicated IAM user + access key per project with bucket-scoped policy&lt;br/&gt;• Bucket versioning enabled — object-level rollback&lt;br/&gt;• Backup bucket: hr-rag-docs-backup (lifecycle rule: replicate daily)" vertex="1">
          <mxGeometry height="70" width="640" x="30" y="730" as="geometry" />
        </mxCell>
        <mxCell id="si-minio-ha-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#F0F4C3;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#827717;spacingLeft=8;" value="High Availability &amp; Backup" vertex="1">
          <mxGeometry height="22" width="640" x="30" y="806" as="geometry" />
        </mxCell>
        <mxCell id="si-minio-ha" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="• &lt;b&gt;Distributed mode&lt;/b&gt; (≥4 nodes) for erasure coding — survives disk/node failure&lt;br/&gt;• MinIO replication → offsite backup MinIO or NFS mount" vertex="1">
          <mxGeometry height="44" width="640" x="30" y="828" as="geometry" />
        </mxCell>
        <mxCell id="si-redis-card" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#B71C1C;strokeWidth=2;arcSize=3;" value="" vertex="1">
          <mxGeometry height="420" width="660" x="720" y="498" as="geometry" />
        </mxCell>
        <mxCell id="si-redis-hdr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B71C1C;strokeColor=#7F0000;strokeWidth=0;fontColor=#ffffff;fontSize=14;fontStyle=1;verticalAlign=middle;arcSize=5;" value="Redis — In-Memory Cache &amp; Pub/Sub" vertex="1">
          <mxGeometry height="38" width="640" x="730" y="506" as="geometry" />
        </mxCell>
        <mxCell id="si-redis-hw-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#FFCDD2;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#B71C1C;spacingLeft=8;" value="Hardware Requirements" vertex="1">
          <mxGeometry height="22" width="640" x="730" y="552" as="geometry" />
        </mxCell>
        <mxCell id="si-redis-hw" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="RAM: &lt;b&gt;32 GB&lt;/b&gt; (all data in-memory — set maxmemory 28gb)      CPU: &lt;b&gt;4 cores&lt;/b&gt; (single-threaded core + I/O threads)&amp;nbsp;&lt;div&gt;Storage: &lt;b&gt;200 GB SSD&lt;/b&gt; (AOF + RDB persistence)&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="640" x="730" y="574" as="geometry" />
        </mxCell>
        <mxCell id="si-redis-net-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#FFCDD2;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#B71C1C;spacingLeft=8;" value="Network &amp; Ports" vertex="1">
          <mxGeometry height="22" width="640" x="730" y="610" as="geometry" />
        </mxCell>
        <mxCell id="si-redis-net" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="• Port 6379 — primary Redis&lt;br/&gt;• Port 6380 — replica (read-only, optional)&lt;br/&gt;• Port 16379 — Redis Cluster bus (cluster mode only)&lt;br/&gt;• Bind to internal network only — requirepass mandatory + TLS recommended" vertex="1">
          <mxGeometry height="70" width="640" x="730" y="632" as="geometry" />
        </mxCell>
        <mxCell id="si-redis-mt-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#FFCDD2;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#B71C1C;spacingLeft=8;" value="Multi-Project Isolation" vertex="1">
          <mxGeometry height="22" width="640" x="730" y="708" as="geometry" />
        </mxCell>
        <mxCell id="si-redis-mt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="• &lt;b&gt;Key prefix per project&lt;/b&gt;: hr_rag:*, finance:*, legal:* (logical isolation)&lt;br/&gt;• Or &lt;b&gt;DB number&lt;/b&gt; per project: DB 0 = hr_rag, DB 1 = finance ... (max 16 DBs)&lt;br/&gt;• ACL per project user: restrict to own keyspace prefix (Redis 6+ ACL)&lt;br/&gt;• Pub/Sub channels: namespace-prefixed (hr_rag:events, finance:events)" vertex="1">
          <mxGeometry height="70" width="640" x="730" y="730" as="geometry" />
        </mxCell>
        <mxCell id="si-redis-ha-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=#FFCDD2;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#B71C1C;spacingLeft=8;" value="High Availability &amp; Persistence" vertex="1">
          <mxGeometry height="22" width="640" x="730" y="806" as="geometry" />
        </mxCell>
        <mxCell id="si-redis-ha" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#1a1a2e;spacingLeft=8;" value="• &lt;b&gt;Redis Sentinel&lt;/b&gt; (3 sentinels) for auto-failover without cluster overhead&lt;br/&gt;• Persistence: RDB every 1h + AOF fsync everysec — balance of speed &amp; durability" vertex="1">
          <mxGeometry height="44" width="640" x="730" y="828" as="geometry" />
        </mxCell>
        <mxCell id="si-summary-bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A237E;strokeColor=#0D1454;strokeWidth=2;arcSize=5;" value="" vertex="1">
          <mxGeometry height="20" width="1360" x="20" y="932" as="geometry" />
        </mxCell>
        <mxCell id="si-summary-label" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#FFA726;" value="Each service: 32 GB RAM · 8 CPU cores · 500 GB–8 TB storage   |   Total shared infra server spec: 128 GB RAM · 32 cores · 10+ TB storage   |   OS: Ubuntu 22.04 LTS + Docker Compose or bare metal" vertex="1">
          <mxGeometry height="24" width="1360" x="20" y="930" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
