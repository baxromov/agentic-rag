        <mxCell id="df-flow-hdr" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#7B1FA2;spacingLeft=10;" value="CRA Auto-Fill Agent Flow (LangGraph · 3 Agents)" vertex="1">
          <mxGeometry height="20" width="1120" x="20" y="917" as="geometry" />
        </mxCell>
        <mxCell id="df-flow-text" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#1a1a2e;spacingLeft=10;" value="Upload Annexes → POST /cra-sessions/{id}/extract → ARQ enqueues run_cra_autofill → LangGraph pipeline:&lt;br/&gt;[1] &lt;b&gt;Extraction Agent&lt;/b&gt;: AnnexTextExtractor + DocxCommentExtractor → LLM .with_structured_output(Pydantic) (per-section) → CRAFieldValue + confidence&lt;br/&gt;[2] &lt;b&gt;Validation Agent&lt;/b&gt;: format checks · required fields · cross-field consistency → ValidationError list&lt;br/&gt;[3] &lt;b&gt;Debug Agent&lt;/b&gt;: root-cause analysis on failures → prompt optimization → retry (max 3) → DONE / FAILED&lt;br/&gt;Frontend polls GET /cra-sessions/{id}/status every 3s → renders 68 fields with confidence badges (auto-saved via Zustand 800ms debounce)" vertex="1">
          <mxGeometry height="72" width="1120" x="20" y="935" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
